# CoinGecko Demo API key — optional. Raises the public rate limit and is sent as the
# `x-cg-demo-api-key` header. Leave empty to use the keyless public endpoint.
# Never commit a real key; copy this file to `.env.local` and fill it there.
VITE_CG_KEY=

# Force the bundled mock dataset instead of the live API. Accepts "true".
# Useful offline or to demo the Stale fallback path deterministically.
VITE_USE_MOCK=
